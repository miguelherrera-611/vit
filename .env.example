APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Bogota
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# ── Sesiones ────────────────────────────────────────────────────
# DESARROLLO:  SESSION_DRIVER=database
# PRODUCCIÓN:  SESSION_DRIVER=redis   ← Obligatorio con 500+ usuarios simultáneos.
#              Con database, cada request escribe en BD = cuello de botella.
SESSION_DRIVER=database
SESSION_LIFETIME=120
# PRODUCCIÓN: SESSION_ENCRYPT=true  ← cifra el contenido de la sesión en BD.
# Cambiarlo invalida sesiones activas existentes (los usuarios se desloguean una vez).
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ── Queue ────────────────────────────────────────────────────────
# DESARROLLO:  QUEUE_CONNECTION=database
# PRODUCCIÓN:  QUEUE_CONNECTION=redis  ← Recomendado. Más rápido y no satura la BD.
QUEUE_CONNECTION=database

# ── Cache ────────────────────────────────────────────────────────
# DESARROLLO:  CACHE_STORE=database
# PRODUCCIÓN:  CACHE_STORE=redis       ← Obligatorio con 500+ usuarios simultáneos.
#              Con database, cada cache hit/miss golpea la BD.
CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# ── Redis (requerido en producción para session, cache y queue) ──
# Instalar en servidor: apt install redis-server  /  brew install redis
# Verificar que la extensión phpredis esté habilitada en el servidor.
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
